    ],
    "steps": [
      { "id": "step-lasagne-01", "section": "ragu", "position": 1, "text": "Heat about 50ml olive oil in a large pan. Add onion, carrot, celery, and a big pinch of salt, then saute for 4-5 minutes.", "language": "en", "timerSeconds": 300 },
      { "id": "step-lasagne-02", "section": "ragu", "position": 2, "text": "Add the garlic, cook for 1 minute, then remove the sofrito from the pan and set it aside.", "language": "en", "timerSeconds": 60 },
      { "id": "step-lasagne-03", "section": "ragu", "position": 3, "text": "Return the pan to the heat with a little more olive oil. Add pork and beef mince, season with salt, and cook for 3-4 minutes to colour the underside before breaking it up.", "language": "en", "timerSeconds": 240 },
      { "id": "step-lasagne-04", "section": "ragu", "position": 4, "text": "Add red wine and reduce by at least 80 percent. Return the sofrito, add passata and Parmesan rind, bring to a simmer, cover, and cook gently for 2-3 hours, stirring occasionally.", "language": "en", "timerSeconds": 9000 },
      { "id": "step-lasagne-05", "section": "ragu", "position": 5, "text": "Stir 100ml milk into the ragu near the end of cooking, then adjust seasoning.", "language": "en" },
      { "id": "step-lasagne-06", "section": "spinach pasta", "position": 6, "text": "Blanch the spinach in boiling salted water for 20 seconds, then chill in ice water. Drain, squeeze dry, and blend with the eggs until smooth.", "language": "en", "timerSeconds": 20 },
      { "id": "step-lasagne-07", "section": "spinach pasta", "position": 7, "text": "Make a well in the Tipo 00 flour, add the spinach egg mixture and a pinch of salt, then work into a dough. Knead until smooth, about 8-10 minutes, and rest for at least 45 minutes.", "language": "en", "timerSeconds": 2700 },
      { "id": "step-lasagne-08", "section": "spinach pasta", "position": 8, "text": "Roll the pasta to about 2mm thick, cut into sheets, blanch for 2 minutes, cool in water, and hold on an oiled tray.", "language": "en", "timerSeconds": 120 },
      { "id": "step-lasagne-09", "section": "bechamel", "position": 9, "text": "Melt butter in a pot over medium heat. Stir in flour and cook for 2 minutes.", "language": "en", "timerSeconds": 120 },
      { "id": "step-lasagne-10", "section": "bechamel", "position": 10, "text": "Whisk in 600ml cold milk in stages until smooth, then simmer for 10 minutes. Season with salt, pepper, and nutmeg.", "language": "en", "timerSeconds": 600 },
      { "id": "step-lasagne-11", "section": "assembly", "position": 11, "text": "Heat the oven to 180C. In a 23 x 30cm oven dish, layer ragu, pasta, bechamel, mozzarella, and Parmesan, repeating until used.", "language": "en", "temperature": { "value": 180, "unit": "c", "raw": "180C" } },
      { "id": "step-lasagne-12", "section": "assembly", "position": 12, "text": "Finish with pasta and a little passata on top, cover with foil, and bake for 30 minutes.", "language": "en", "timerSeconds": 1800, "temperature": { "value": 180, "unit": "c", "raw": "180C" } },
      { "id": "step-lasagne-13", "section": "assembly", "position": 13, "text": "Remove the foil, top with basil, mozzarella, and Parmesan, then bake for another 15 minutes. Grill briefly if needed until golden.", "language": "en", "timerSeconds": 900 },
      { "id": "step-lasagne-14", "section": "serve", "position": 14, "text": "Rest for 10-15 minutes before slicing and serving.", "language": "en", "timerSeconds": 900 }
    ],
