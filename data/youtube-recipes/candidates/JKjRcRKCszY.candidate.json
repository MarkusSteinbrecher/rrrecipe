          }
        ]
      },
      {
        "id": "step-e193e2a3-8487-4ca3-9eb8-3716f374b950",
        "position": 4,
        "text": "Cover the bowl with a tea towel and let it rest for 30 minutes.",
        "language": "en",
        "timerSeconds": 1800,
        "mediaAnchors": [
          {
            "sourceId": "source-0c325bed-9276-4881-a863-fd1cbe9152f3",
