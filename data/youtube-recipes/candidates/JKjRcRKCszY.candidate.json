    "steps": [
      {
        "id": "step-6718d770-436c-4f58-81a6-102be198ed5a",
        "position": 1,
        "text": "Add your flour to a large bowl. In a smaller bowl or glass measuring jug, add 475ml (16 fl oz) of warm water (32°C / 90°F) and the dry yeast and mix until dissolved.",
        "language": "en",
        "mediaAnchors": [
          {
            "sourceId": "source-0c325bed-9276-4881-a863-fd1cbe9152f3",
            "startSeconds": 0,
            "label": "add your flour to a large bowl. in a",
            "confidence": "estimated"
          }
        ]
      },
      {
        "id": "step-4f2fca65-0a66-4dd0-8839-c70fa8d39ca5",
        "position": 2,
        "text": "Add the water yeast mixture to the flour along with 2 tablespoons (30ml) of olive oil. Start mixing and then add in the cooking salt.",
        "language": "en",
        "mediaAnchors": [
          {
            "sourceId": "source-0c325bed-9276-4881-a863-fd1cbe9152f3",
