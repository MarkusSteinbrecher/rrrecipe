    "steps": [
      { "id": "step-pbp-01", "section": "crust", "position": 1, "text": "Prepare a loose-bottom pie tin. Mix cornflakes with 80g melted butter, brown sugar, and cinnamon, then toast until crisp and fragrant.", "language": "en" },
      { "id": "step-pbp-02", "section": "crust", "position": 2, "text": "Crush the chocolate sandwich cookies and combine them with the toasted cinnamon cereal, 60g melted butter, and a pinch of salt.", "language": "en" },
      { "id": "step-pbp-03", "section": "crust", "position": 3, "text": "Press the crumb mixture firmly into the base and sides of the tin, then chill until set.", "language": "en", "timerSeconds": 1800 },
      { "id": "step-pbp-04", "section": "pastry cream filling", "position": 4, "text": "Whisk egg yolks, caster sugar, and cornflour until smooth. Bloom the powdered gelatine according to the packet instructions.", "language": "en" },
      { "id": "step-pbp-05", "section": "pastry cream filling", "position": 5, "text": "Heat the milk with vanilla until steaming. Temper it into the yolk mixture, then return everything to the pan and cook, whisking, until thick.", "language": "en" },
      { "id": "step-pbp-06", "section": "pastry cream filling", "position": 6, "text": "Whisk in the bloomed gelatine while the pastry cream is hot, then cool until warm but not set.", "language": "en" },
      { "id": "step-pbp-07", "section": "pastry cream filling", "position": 7, "text": "Beat in the very soft butter and dark roast peanut butter until smooth and fully emulsified.", "language": "en" },
      { "id": "step-pbp-08", "section": "assembly", "position": 8, "text": "Spoon the peanut butter filling into the chilled crust, level the top, and chill until fully set.", "language": "en", "timerSeconds": 10800 },
      { "id": "step-pbp-09", "section": "finish", "position": 9, "text": "Whip equal amounts of mascarpone cream and double cream to a soft piping or spooning consistency.", "language": "en" },
      { "id": "step-pbp-10", "section": "finish", "position": 10, "text": "Top the set pie with the mascarpone cream mixture and finish with dark roasted peanuts.", "language": "en" }
