    "steps": [
      { "id": "step-banoffee-01", "section": "cookie dough", "position": 1, "text": "Brown the butter, then let it cool until liquid but no longer hot.", "language": "en" },
      { "id": "step-banoffee-02", "section": "cookie dough", "position": 2, "text": "Mix the cooled browned butter with caster sugar, light soft brown sugar, vanilla, egg yolk, and mashed banana until combined.", "language": "en" },
      { "id": "step-banoffee-03", "section": "cookie dough", "position": 3, "text": "In a separate bowl, combine plain flour, baking powder, sea salt, bicarbonate of soda, and toasted milk powder.", "language": "en" },
      { "id": "step-banoffee-04", "section": "cookie dough", "position": 4, "text": "Fold the dry ingredients into the banana butter mixture, then fold in the milk and dark chocolate chips.", "language": "en" },
      { "id": "step-banoffee-05", "section": "cookie dough", "position": 5, "text": "Portion the dough into large cookie balls and chill until firm.", "language": "en", "timerSeconds": 3600 },
      { "id": "step-banoffee-06", "section": "bake", "position": 6, "text": "Bake the chilled cookies on lined trays until spread, golden at the edges, and just set in the centre. Cool completely before decorating.", "language": "en" },
      { "id": "step-banoffee-07", "section": "buttercream", "position": 7, "text": "Beat the soft butter until smooth, then add sifted icing sugar and vanilla and beat until pale.", "language": "en" },
      { "id": "step-banoffee-08", "section": "buttercream", "position": 8, "text": "Beat in 2-3 tablespoons double cream until the buttercream is smooth and pipeable.", "language": "en" },
